# Copy this file to .env and fill in the real values.
# .env is gitignored — never commit your real key (this repo is public).

# Google AI Studio API key: https://aistudio.google.com/apikey
GOOGLE_API_KEY=your-key-here

# Gemini model id. Verify available ids against the API, don't trust old examples.
#   gemini-3.1-flash-lite  -> cheap & fast, good for tests
#   gemini-3.5-flash       -> more capable, for real reports
GEMINI_MODEL=gemini-3.1-flash-lite
