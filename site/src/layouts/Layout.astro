---
import Head from "@components/Head.astro";
import Header from "@components/Header.astro";
import Footer from "@components/Footer.astro";
import Pagefind from "@components/PageFind.astro";
import { SITE } from "@consts";

type Props = {
  title: string;
  description: string;
};

const { title, description } = Astro.props;

// Avoid "scout-agent | scout-agent" on pages whose title is already the site name.
const pageTitle = title === SITE.TITLE ? title : `${title} | ${SITE.TITLE}`;
---

<!doctype html>
<html lang="en">
  <head>
    <Head title={pageTitle} description={description} />
  </head>
  <body>
    <noscript>
      <style>
        .animate{
          opacity:1;
          translate: var(--tw-translate-x) calc(var(--spacing) * 0);
        }
      </style>
    </noscript>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
    <Pagefind />
  </body>
</html>
